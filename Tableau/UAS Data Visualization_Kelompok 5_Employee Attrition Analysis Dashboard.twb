      <repository-location derived-from='https://public.tableau.com/workbooks/UASDataVisualization_Kelompok5_AnalisisAttritionKaryawan/Dashboard5?rev=' id='131354475' path='/workbooks/UASDataVisualization_Kelompok5_AnalisisAttritionKaryawan' revision='' />
      <style />
      <size maxheight='900' maxwidth='1580' minheight='900' minwidth='1580' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98222' id='3' is-scaled='1' param='D:/UNIVERSITAS HARAPAN BANGSA/SEMESTER 6/Data Visualization/UAS Data Visualization_Kelompok 5_Employee Attrition Analysis Dashboard.twb Files/Image/WhatsApp Image 2026-06-24 at 10.56.28.jpeg' type-v2='bitmap' w='98988' x='506' y='889'>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
