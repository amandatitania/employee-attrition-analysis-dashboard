                            <encoding attr='space' class='0' field='[federated.1gob3v41h04nkw11juitb09hwtsp].[none:Years At Company:qk]' field-type='quantitative' max='20' min='2' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
