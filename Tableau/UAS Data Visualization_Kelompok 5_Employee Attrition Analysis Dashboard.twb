                <story-points>
                  <story-point caption='Dashboard ini menyajikan gambaran umum mengenai tingkat attrition karyawan di perusahaan. Dari total 1.470 karyawan, sebanyak 237 karyawan telah meninggalkan perusahaan, sehingga menghasilkan tingkat attrition sebesar 16,12%, sementara 1.233 karyawan masih aktif bekerja. Rata-rata usia karyawan di perusahaan adalah 37 tahun. Selain itu, dashboard ini juga memvisualisasikan distribusi attrition berdasarkan departemen, kelompok usia, bidang pendidikan, dan tingkat kepuasan kerja, sehingga memberikan wawasan yang berharga mengenai tren tenaga kerja serta faktor-faktor potensial yang memengaruhi turnover karyawan.&#10;' captured-sheet='Employee Attration &amp; Workforce Insight Dashboard' id='1'>
                    <capturedDeltas>
                      <worksheet name='Attration Rate by Gender for Different Age Group'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1gob3v41h04nkw11juitb09hwtsp].[usr:Calculation_2335116421466685444:qk]' field-type='quantitative' max='2' min='0' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='1' field='[federated.1gob3v41h04nkw11juitb09hwtsp].[usr:Calculation_2335116421466685444:qk]' field-type='quantitative' fold='true' max='2' min='0' range-type='fixed' scope='rows' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                      <worksheet name='Education Field wise Attrition'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1gob3v41h04nkw11juitb09hwtsp].[sum:Calculation_2335116421429559296:qk]' field-type='quantitative' max='103' min='-1' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                      <worksheet name='No of Employee by Age Group'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1gob3v41h04nkw11juitb09hwtsp].[sum:Employee Count:qk]' field-type='quantitative' max='266' min='14' range-type='fixed' scope='rows' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Dashboard ini menganalisis faktor-faktor utama yang memengaruhi attrition karyawan, seperti overtime, pendapatan bulanan, lama bekerja di perusahaan, dan jarak tempat tinggal. Faktor-faktor tersebut membantu mengidentifikasi pola turnover karyawan serta mendukung penyusunan strategi retensi yang lebih baik.&#10;' captured-sheet='Analisys of Factors Influencing Employee Attrition' id='2'>
                    <capturedDeltas>
                      <worksheet name='Years at Company vs Attrition Rate'>
                        <style delta-type='added'>
